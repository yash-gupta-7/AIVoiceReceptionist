# Copy to .env and fill in. Every variable used by the app is listed here.

# PostgreSQL (docker compose service name "db")
DATABASE_URL=postgresql+asyncpg://clinic:clinic@db:5432/clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic
POSTGRES_DB=clinic

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me

# LLM provider: "grok" (default) or "fake" (deterministic, for dev without a key)
LLM_PROVIDER=grok
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# Vapi (primary voice platform)
VAPI_API_KEY=
VAPI_SECRET=change-me-random           # shared secret Vapi sends in x-vapi-secret
PUBLIC_URL=http://localhost:8000       # public base URL Vapi uses to reach the tool webhook

# Cliniko PMS write-back (optional; mock PMS used when empty)
CLINIKO_API_KEY=
CLINIKO_BASE_URL=https://api.au4.cliniko.com/v1

# Twilio (legacy fallback voice path). Auth token validates webhook signatures.
TWILIO_AUTH_TOKEN=

# Prompt version directory under prompts/ (falls back across versions per file)
PROMPT_VERSION=v2

# Clinic identity + locale
CLINIC_NAME=City Dental Care
CLINIC_TZ=Europe/London

# Number to dial when transferring to a human (legacy Twilio path only)
TRANSFER_NUMBER=+15550100

# Seed admin login for the dashboard
ADMIN_EMAIL=admin@clinic.local
ADMIN_PASSWORD=admin123

# Live phone number attached to the Vapi assistant
VAPI_PHONE_NUMBER=
